{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/app",
      "dest": "/public/app.html"
    },
    {
      "src": "/app.html",
      "dest": "/public/app.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "env": {
    "JWT_SECRET": "sges-slu-kafin-hausa-2024-secret",
    "DB_PATH": "/tmp/sges.db"
  }
}
